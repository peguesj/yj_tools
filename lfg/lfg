#!/usr/bin/env bash
# =============================================================================
# lfg - Local File Guardian
# =============================================================================
# Suite dispatcher with splash screen for disk management tools.
#
# Modules:
#   wtfs      Where's The Free Space - disk usage viewer
#   dtf       Delete Temp Files - cache cleaner
#   btau      Back That App Up - backup manager
#   devdrive  Developer Drive - symlink forest manager
#
# Usage:
#   lfg                          # Splash screen
#   lfg wtfs [path]              # Disk usage viewer
#   lfg dtf [--force] [opts]     # Cache cleaner
#   lfg btau [cmd] [opts]        # Backup manager
#   lfg devdrive [cmd] [opts]    # Developer drive manager
#   lfg dashboard                # Combined dashboard
#   lfg --help                   # Show help
# =============================================================================
set -euo pipefail

readonly LFG_VERSION="2.4.0"
SELF="$0"
[[ -L "$SELF" ]] && SELF="$(readlink "$SELF")"
readonly LFG_DIR="$(cd "$(dirname "$SELF")" && pwd)"
readonly VIEWER="$LFG_DIR/LFG.app/Contents/MacOS/LFG"

# Build viewer app bundle if needed
ensure_viewer() {
    if [[ ! -x "$VIEWER" ]] || [[ "$LFG_DIR/viewer.swift" -nt "$VIEWER" ]]; then
        echo "Building LFG.app..."
        make -C "$LFG_DIR" LFG.app 2>&1
    fi
}

show_help() {
    cat <<'HELP'
lfg - Local File Guardian v2.4.0

SCAN:
    wtfs [path]                  Where's The Free Space (configured paths)

CLEAN:
    dtf                          Delete Temp Files (dry run)
    dtf --force                  Execute cache cleanup
    dtf --only <name>            Clean single cache by name

BACKUP:
    btau                         Back That App Up (status view)
    btau <command> [opts]        Backup CLI

DRIVE:
    devdrive                     Developer Drive (status view)
    devdrive mount|unmount|sync|verify|create|config|auto-move

FORENSICS:
    stfu                         Source Tree Forensics (dry run)
    stfu --execute               Execute actions with confirmation
    stfu deps|fingerprint|duplicates|libraries|envs
    stfu merge-check <a> <b>     Check merge feasibility
    stfu scaffold <lib>          Generate shared library scaffold
    stfu archive <project>       Archive a project

AI:
    ai config [show|get|set]     AI model configuration
    ai analyze|compare|suggest   AI-powered analysis

CHAT:
    chat                         Open AI chat interface
    chat send "<message>"        Send message, print response

SEARCH:
    search <query>               Semantic search across projects/files/history
    search index                 Rebuild search index
    search update                Incremental index update

SETTINGS:
    settings show [--json]       Show all settings
    settings get|set <key>       Read/write settings
    settings paths add|remove    Manage scan directories
    settings access <mod> add|remove <path>  Module permissions
    settings reset               Reset to defaults

COMMANDS:
    lfg                          Splash screen
    lfg dashboard                Combined dashboard
    lfg menubar                  Menubar status app
    lfg --help / --version

SHORTCUTS (viewer):
    Cmd+1-5  Main tabs    Cmd+6  Chat    Cmd+7  AI    Cmd+8  Settings

HELP
}

# Route based on how we were invoked (alias detection)
INVOKED_AS="$(basename "$0")"
case "$INVOKED_AS" in
    wtfs)
        ensure_viewer
        exec "$LFG_DIR/lib/scan.sh" "$@"
        ;;
    dtf)
        ensure_viewer
        exec "$LFG_DIR/lib/clean.sh" "$@"
        ;;
    btau)
        ensure_viewer
        exec "$LFG_DIR/lib/btau.sh" "$@"
        ;;
esac

# Normal dispatch
case "${1:-}" in
    wtfs|scan)
        shift
        ensure_viewer
        exec "$LFG_DIR/lib/scan.sh" "$@"
        ;;
    dtf|clean)
        shift
        ensure_viewer
        exec "$LFG_DIR/lib/clean.sh" "$@"
        ;;
    btau|backup)
        shift
        ensure_viewer
        exec "$LFG_DIR/lib/btau.sh" "$@"
        ;;
    devdrive|dd)
        shift
        ensure_viewer
        exec "$LFG_DIR/lib/devdrive.sh" "$@"
        ;;
    dashboard)
        shift || true
        ensure_viewer
        exec "$LFG_DIR/lib/dashboard.sh" "$@"
        ;;
    settings)
        shift
        exec bash "$LFG_DIR/lib/settings.sh" "$@"
        ;;
    ai)
        shift
        exec bash "$LFG_DIR/lib/ai.sh" "$@"
        ;;
    chat)
        shift
        ensure_viewer
        exec bash "$LFG_DIR/lib/chat.sh" "$@"
        ;;
    search)
        shift
        exec bash "$LFG_DIR/lib/search.sh" "$@"
        ;;
    stfu)
        shift || true
        exec bash "$LFG_DIR/lib/stfu.sh" "$@"
        ;;
    menubar)
        # Build menubar app bundle if needed
        menubar_bin="$LFG_DIR/LFG Menubar.app/Contents/MacOS/LFG Menubar"
        if [[ ! -x "$menubar_bin" ]] || [[ "$LFG_DIR/menubar.swift" -nt "$menubar_bin" ]]; then
            echo "Building LFG Menubar.app..."
            make -C "$LFG_DIR" "LFG Menubar.app" 2>&1
        fi
        "$menubar_bin" &
        disown
        echo "LFG menubar started."
        exit 0
        ;;
    --help|-h)
        show_help
        ;;
    --version|-v)
        echo "lfg v${LFG_VERSION}"
        ;;
    "")
        # No args = splash screen
        ensure_viewer
        exec "$LFG_DIR/lib/splash.sh"
        ;;
    *)
        echo "Unknown command: $1"
        echo "Run 'lfg --help' for usage"
        exit 1
        ;;
esac
